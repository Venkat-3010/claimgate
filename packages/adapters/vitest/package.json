{
  "name": "@claimgate/adapter-vitest",
  "version": "0.1.0",
  "description": "Vitest gate adapter — catches skips, deleted tests, and false greens",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Venkat-3010/claimgate.git",
    "directory": "packages/adapters/vitest"
  },
  "homepage": "https://github.com/Venkat-3010/claimgate#readme",
  "bugs": {
    "url": "https://github.com/Venkat-3010/claimgate/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@claimgate/core": "workspace:*",
    "fast-glob": "^3.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
